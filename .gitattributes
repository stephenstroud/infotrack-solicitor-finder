# Normalise line endings: let Git decide in the repo, check out native on each OS.
* text=auto

# Force LF for cross-platform script/config files.
*.sh    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Treat known binaries as binary.
*.png   binary
*.jpg   binary
*.ico   binary
*.pdf   binary
